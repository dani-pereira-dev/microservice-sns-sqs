{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": false,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["libs/shared/src/*"],
      "@orders/*": ["apps/orders/src/*"],
      "@payments/*": ["apps/payments/src/*"],
      "@notification/*": ["apps/notification/src/*"],
      "@products/*": ["apps/products/src/*"],
      "@cart/*": ["apps/cart/src/*"]
    },
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}

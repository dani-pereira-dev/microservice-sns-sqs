{
  "name": "microsrvicios-sns-sqs",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start:dev": "node scripts/start-all-dev.js",
    "db:reset": "node scripts/reset-databases.js",
    "seed": "node scripts/seed-data.js",
    "seed:products": "node scripts/seed-data.js --entity products --count 5000",
    "queues:purge": "node scripts/purge-queues.js",
    "reset:all": "npm run db:reset && npm run queues:purge",
    "build:orders": "tsc -p apps/orders/tsconfig.json && tsc-alias -p apps/orders/tsconfig.json",
    "build:payments": "tsc -p apps/payments/tsconfig.json && tsc-alias -p apps/payments/tsconfig.json",
    "build:products": "tsc -p apps/products/tsconfig.json && tsc-alias -p apps/products/tsconfig.json",
    "build:cart": "tsc -p apps/cart/tsconfig.json && tsc-alias -p apps/cart/tsconfig.json",
    "build:notification:legacy": "tsc -p apps/notification/tsconfig.json && tsc-alias -p apps/notification/tsconfig.json",
    "build:notification:lambda": "node scripts/build-notification-lambda.js",
    "package:notification:lambda": "npm run build:notification:lambda && node scripts/run-serverless.js package",
    "deploy:notification:lambda": "npm run build:notification:lambda && node scripts/run-serverless.js deploy",
    "remove:notification:lambda": "node scripts/run-serverless.js remove",
    "info:notification:lambda": "node scripts/run-serverless.js info",
    "build": "npm run build:orders && npm run build:payments && npm run build:products && npm run build:cart && npm run build:notification:lambda",
    "start:orders": "node dist/orders/apps/orders/src/main.js",
    "start:payments": "node dist/payments/apps/payments/src/main.js",
    "start:products": "node dist/products/apps/products/src/main.js",
    "start:cart": "node dist/cart/apps/cart/src/main.js",
    "start:dev:orders": "ts-node-dev -r tsconfig-paths/register --project apps/orders/tsconfig.json --respawn --transpile-only apps/orders/src/main.ts",
    "start:dev:payments": "ts-node-dev -r tsconfig-paths/register --project apps/payments/tsconfig.json --respawn --transpile-only apps/payments/src/main.ts",
    "start:dev:products": "ts-node-dev -r tsconfig-paths/register --project apps/products/tsconfig.json --respawn --transpile-only apps/products/src/main.ts",
    "start:dev:cart": "ts-node-dev -r tsconfig-paths/register --project apps/cart/tsconfig.json --respawn --transpile-only apps/cart/src/main.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Monorepo simple con tres microservicios NestJS",
  "dependencies": {
    "@aws-sdk/client-sns": "^3.1023.0",
    "@aws-sdk/client-sqs": "^3.1023.0",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "better-sqlite3": "^12.8.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.10.0",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "esbuild": "^0.28.0",
    "serverless": "^3.40.0",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2"
  }
}

NODE_ENV=development

ORDERS_PORT=3001
PAYMENTS_PORT=3002
PRODUCTS_PORT=3004
CART_PORT=3005
ORDERS_DB_PATH=data/orders.sqlite
PAYMENTS_DB_PATH=data/payments.sqlite
# Payments: Postgres + TypeORM (local: `npm run docker:payments:up`, puerto 5434).
PAYMENTS_DATABASE_URL=postgresql://app:app@localhost:5434/payments
# true en local la primera vez para crear tablas; en producción usar migraciones SQL.
PAYMENTS_TYPEORM_SYNCHRONIZE=true
PAYMENTS_DATABASE_SSL_REJECT_UNAUTHORIZED=false
CART_DB_PATH=data/cart.sqlite

# Products: event store en Postgres alojado en AWS. Obligatorio para levantar el microservicio.
# Podés poner sslmode= en la URL para otros clientes; el servicio quita esos params y usa la opción ssl de Node (ver abajo).
PRODUCTS_DATABASE_URL=
# Solo desarrollo: true crea/ajusta la tabla con TypeORM (no usar en producción).
PRODUCTS_TYPEORM_SYNCHRONIZE=false
# TLS Node→Postgres remoto: false evita "self-signed certificate in certificate chain" sin montar la CA de AWS.
# true solo si configurás la CA de RDS y querés verificación estricta.
PRODUCTS_DATABASE_SSL_REJECT_UNAUTHORIZED=false
# Relay outbox: reintenta SNS para filas con published_at null (ms, mínimo 500).
PRODUCTS_OUTBOX_POLL_MS=5000
# Products: proyección en DynamoDB para lecturas HTTP (ProductsQueryService). Obligatoria para GET/list de productos.
# Ítems: PK `id` (string) + title, price, active, createdAt, updatedAt (como el contrato Product).
PRODUCTS_PROJECTION_TABLE_NAME=

# Clientes AWS (SNS, SQS, DynamoDB de la proyección de products, etc.).
AWS_REGION=us-east-1
AWS_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

AWS_SNS_CHECKOUT_INITIATED_TOPIC_ARN=
AWS_SQS_ORDERS_CHECKOUT_INITIATED_QUEUE_URL=
AWS_SNS_ORDER_CREATED_TOPIC_ARN=
AWS_SQS_PAYMENTS_ORDER_CREATED_QUEUE_URL=
AWS_SNS_PAYMENT_CONFIRMED_TOPIC_ARN=
AWS_SNS_ORDER_STATUS_TOPIC_ARN=
AWS_SNS_PRODUCT_EVENTS_TOPIC_ARN=
AWS_SQS_ORDERS_PAYMENT_CONFIRMED_QUEUE_URL=
AWS_SQS_NOTIFICATION_ORDER_STATUS_QUEUE_URL=
AWS_SQS_CART_PRODUCT_EVENTS_QUEUE_URL=
# Misma suscripción SNS que la cola del cart (`product.created` / `product.updated`). Consumer Nest en `products` hace upsert en Dynamo (`PRODUCTS_PROJECTION_TABLE_NAME`). Opcional: DLQ en la cola; una Lambda puede sustituir al consumer usando la misma URL.
AWS_SQS_PRODUCTS_PROJECTION_QUEUE_URL=
RESEND_API_KEY=
NOTIFICATION_EMAIL_FROM=onboarding@resend.dev
NOTIFICATION_DEFAULT_TO_EMAIL=
NOTIFICATION_LAMBDA_FUNCTION_NAME=notification-order-status
